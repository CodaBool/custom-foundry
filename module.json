{
  "id": "custom-foundry",
  "title": "Custom CodaBool FoundryVTT",
  "version": "0.0.7",
  "compatibility": {
    "minimum": "13",
    "verified": "14"
  },
  "authors": [
    {
      "name": "CodaBool",
      "discord": "codabool",
      "email": "codabool@pm.me",
      "url": "https://codabool.com",
      "flags": {}
    }
  ],
  "esmodules": ["main.js", "mothership.js"],
  "socket": true,
  "url": "https://github.com/CodaBool/custom-foundry",
  "bugs": "https://github.com/CodaBool/custom-foundry/issues",
  "manifest": "https://raw.githubusercontent.com/CodaBool/custom-foundry/main/module.json",
  "download": "https://github.com/CodaBool/custom-foundry/archive/v0.0.7.zip",
  "packs": [
    {
      "name": "codabool-scene",
      "label": "codabool-scene",
      "path": "packs/scene",
      "type": "Scene",
      "ownership": {
        "PLAYER": "NONE",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "codabool-roll",
      "label": "codabool-roll",
      "path": "packs/roll",
      "type": "RollTable",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "codabool-journal",
      "label": "codabool-journal",
      "path": "packs/journal",
      "type": "JournalEntry",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "codabool-macros",
      "label": "codabool-macros",
      "path": "packs/macro",
      "type": "Macro",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "codabool-item",
      "label": "codabool-item",
      "path": "packs/item",
      "type": "Item",
      "system": "mosh",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "codabool-music",
      "label": "codabool-music",
      "path": "packs/music",
      "type": "Playlist",
      "ownership": {
        "PLAYER": "NONE",
        "ASSISTANT": "OWNER"
      }
    }
  ],
  "description": "",
  "flags": {}
}
